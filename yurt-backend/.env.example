# ──────────────────────────────────────────────────────────────
# .env.example — Ortam değişkenleri şablonu
# Kullanım: Bu dosyayı kopyalayın →  cp .env.example .env
# Ardından kendi değerlerinizi girin. .env asla commit edilmez!
# ──────────────────────────────────────────────────────────────

# PostgreSQL Veritabanı Bağlantısı (Neon veya yerel sunucu)
DB_HOST=your_db_host_here
DB_PORT=5432
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=your_db_name_here

# JWT (JSON Web Token) gizli anahtarı — güçlü, rastgele bir değer girin
JWT_SECRET=your_super_secret_jwt_key_here

# SMTP — Email gönderimi için (örn: Mailtrap, Gmail)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here

# Uygulama
PORT=3000
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000
